using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;
using QuoraBackend.Data;

[ApiController]
[Route("api/[controller]")]
public class FollowController : ControllerBase
{
    private readonly AppDbContext _context;

    public FollowController(AppDbContext context)
    {
        _context = context;
    }

    // ✅ FOLLOW USER
    [HttpPost]
    public async Task<IActionResult> Follow(int followerId, int followingId)
    {
        if (followerId == followingId)
            return BadRequest("You cannot follow yourself");

        var exists = await _context.Follows
            .AnyAsync(f => f.FollowerId == followerId && f.FollowingId == followingId);

        if (exists)
            return BadRequest("Already following");

        var follow = new Follow
        {
            FollowerId = followerId,
            FollowingId = followingId
        };

        _context.Follows.Add(follow);
        await _context.SaveChangesAsync();

        return Ok(follow);
    }

    // ✅ UNFOLLOW
    [HttpDelete]
    public async Task<IActionResult> Unfollow(int followerId, int followingId)
    {
        var follow = await _context.Follows
            .FirstOrDefaultAsync(f => f.FollowerId == followerId && f.FollowingId == followingId);

        if (follow == null)
            return NotFound();

        _context.Follows.Remove(follow);
        await _context.SaveChangesAsync();

        return Ok("Unfollowed");
    }

    // ✅ SUGGEST USERS
    [HttpGet("suggest/{userId}")]
    public async Task<IActionResult> Suggest(int userId)
    {
        var followingIds = await _context.Follows
            .Where(f => f.FollowerId == userId)
            .Select(f => f.FollowingId)
            .ToListAsync();

        var users = await _context.Users
            .Where(u => u.Id != userId)
            .Where(u => !followingIds.Contains(u.Id))
            .Take(10)
            .ToListAsync();

        return Ok(users);
    }
}